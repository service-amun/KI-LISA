# KI-LISA Konfiguration — diese Datei als ".env" nach apps/backend/ kopieren

# Pflicht — kostenlos auf console.groq.com
GROQ_API_KEY=gsk_dein_key_hier

# Für Web-Suche — kostenlos auf app.tavily.com
TAVILY_API_KEY=tvly_dein_key_hier

# Optional — für Claude-Modelle (anthropic.com)
ANTHROPIC_API_KEY=sk-ant-dein_key_hier

# DSGVO: Wie lange Daten aufbewahrt werden (Tage)
AILIZA_DATA_RETENTION_DAYS=90

# Human Oversight für kritische Entscheidungen
AILIZA_HUMAN_OVERSIGHT=true
