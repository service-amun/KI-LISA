# ══════════════════════════════════════════════════════════════════
#  KI-LISA / AILIZA — Konfiguration
#  Diese Datei als "apps/backend/.env" kopieren und ausfüllen.
#  NIEMALS echte Keys in diese Datei oder ins Git eintragen!
# ══════════════════════════════════════════════════════════════════

# ── KI-Modelle ────────────────────────────────────────────────────
# Groq (kostenlos) → console.groq.com
GROQ_API_KEY=gsk_dein_key_hier

# Tavily Web-Suche (kostenlos) → app.tavily.com
TAVILY_API_KEY=tvly_dein_key_hier

# Optional: Anthropic Claude (anthropic.com)
ANTHROPIC_API_KEY=sk-ant-dein_key_hier

# Optional: OpenRouter (openrouter.ai) — Zugang zu vielen Modellen
OPENROUTER_API_KEY=sk-or-dein_key_hier

# Standard-Modell: groq (Standard), anthropic, openrouter
AILIZA_MODEL=groq

# ── Datenbank ─────────────────────────────────────────────────────
AILIZA_DB_PATH=./data/kilisa.db
AILIZA_AUDIT_DB_PATH=./data/audit.db
AILIZA_MEMORY_DB_PATH=./data/reflection.db

# ── DSGVO Einstellungen ───────────────────────────────────────────
# Datenhaltung in Tagen (DSGVO Art. 5 Abs. 1e)
AILIZA_DATA_RETENTION_DAYS=90

# PII automatisch pseudonymisieren (true = aktiv, empfohlen)
AILIZA_PSEUDONYMIZE=true

# Audit-Trail verschlüsseln (true = extra Sicherheit)
AILIZA_ENCRYPT_STORAGE=false

# ── EU AI Act Einstellungen ───────────────────────────────────────
# Menschliche Aufsicht für Hochrisiko-Anfragen (Art. 14)
AILIZA_HUMAN_OVERSIGHT=true

# KI-Transparenz-Hinweis in jeder Antwort (Art. 52)
AILIZA_TRANSPARENCY=true

# Risikoklasse: limited (Standard für KMU), high
AILIZA_RISK_LEVEL=limited

# ── Server ────────────────────────────────────────────────────────
AILIZA_HOST=0.0.0.0
AILIZA_PORT=8001
AILIZA_DEBUG=false

# Büro-Netzwerkmodus: 1 = alle Kollegen im WLAN können AILIZA nutzen
# 0 = nur der lokale PC (sicherer für Einzelplatz)
AILIZA_NETZWERK=0

# ── Zugriffsschutz ────────────────────────────────────────────────
# Optionaler Zugangscode für AILIZA (leer lassen = kein Schutz nötig)
# Empfehlung: min. 8 Zeichen, z.B. Firmenname + Jahreszahl
AILIZA_ACCESS_PIN=

# ── Unternehmensdaten (für DSGVO Ersthinweis Art. 13) ─────────────
AILIZA_COMPANY_NAME=Muster GmbH
AILIZA_DSB_EMAIL=datenschutz@muster-gmbh.de

# ── Sicherheit ────────────────────────────────────────────────────
# Admin-Token für geschützte Endpunkte (Audit-Log, Compliance-Check)
# Empfehlung: python -c "import secrets; print(secrets.token_hex(32))"
AILIZA_ADMIN_TOKEN=dein_admin_token_hier
